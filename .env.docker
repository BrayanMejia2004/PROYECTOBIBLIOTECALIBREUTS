# =============================================================================
# Variables de entorno para Docker Compose
# =============================================================================
# Copia este archivo a .env y completa los valores

# -----------------------------------------------------------------------------
# MongoDB Atlas
# -----------------------------------------------------------------------------
# Reemplaza con tu URI de MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/biblioteca_uts

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# IMPORTANTE: En producción usa una clave segura (mínimo 256 bits)
JWT_SECRET=biblioteca-uts-secret-key-production-change-this-256-bits-minimum

# -----------------------------------------------------------------------------
# Tiempos de expiración (opcional)
# -----------------------------------------------------------------------------
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
