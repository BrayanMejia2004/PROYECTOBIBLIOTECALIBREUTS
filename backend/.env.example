# =============================================================================
# CONFIGURACIÓN DE LA APLICACIÓN - Biblioteca UTS
# =============================================================================
# Copia este archivo a .env y completa los valores

# -----------------------------------------------------------------------------
# Perfil de Spring Boot
# -----------------------------------------------------------------------------
# Opciones: dev (desarrollo), prod (producción)
# En dev usa localhost, en prod requiere MONGODB_URI
SPRING_PROFILES_ACTIVE=dev

# -----------------------------------------------------------------------------
# Base de Datos MongoDB
# -----------------------------------------------------------------------------
# URI de conexión a MongoDB Atlas (reemplaza con tus credenciales)
# REQUERIDO en perfil 'prod'
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/biblioteca_uts

# -----------------------------------------------------------------------------
# Seguridad - JWT
# -----------------------------------------------------------------------------
# Clave secreta para firmar tokens JWT (mínimo 256 bits)
# Genera una nueva con: openssl rand -base64 64
JWT_SECRET=tu-clave-secreta-muy-larga-y-segura-de-al-menos-256-bits

# Tiempo de expiración del access token en milisegundos (default: 24 horas)
JWT_EXPIRATION=86400000

# Tiempo de expiración del refresh token en milisegundos (default: 7 días)
JWT_REFRESH_EXPIRATION=604800000

# -----------------------------------------------------------------------------
# Configuración CORS
# -----------------------------------------------------------------------------
# URLs separadas por coma de los frontend permitidos
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Rate Limiting (Opcional - valores por defecto ya definidos en application.yml)
# -----------------------------------------------------------------------------
# RATE_LIMIT_AUTH_MAX_ATTEMPTS=5
# RATE_LIMIT_AUTH_WINDOW_MINUTES=15
# RATE_LIMIT_REGISTER_MAX_ATTEMPTS=3
# RATE_LIMIT_REGISTER_WINDOW_MINUTES=60
# RATE_LIMIT_GENERAL_MAX_REQUESTS=100
# RATE_LIMIT_GENERAL_WINDOW_MINUTES=1
